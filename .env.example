# ═════════════════════════════════════════════════════════════════════
# KIS Trading Bot — Configuration
# ═════════════════════════════════════════════════════════════════════

# ── Run Mode ─────────────────────────────────────────────────────────
# MOCK = KIS 모의투자 서버 (paper trading, requires credentials)
# REAL = KIS 실전투자 서버 (live trading, real money!)
RUN_MODE=MOCK

# ── KIS API Credentials (한국 주식 / 공용) ──────────────────────────
# 1. https://apiportal.koreainvestment.com/ 에서 앱 등록
# 2. 발급받은 App Key / App Secret 입력
# 3. 모의투자 계좌번호 입력 (RUN_MODE=MOCK 일 때)
#    실전 계좌번호 입력 (RUN_MODE=REAL 일 때)
KIS_API_KEY=your_api_key_here
KIS_API_SECRET=your_api_secret_here
KIS_ACC_NO=50012345-01

# ── KIS API Credentials (미국 주식 전용, 비워두면 위 공용 키 사용) ──
# 해외주식용 별도 앱키가 있을 경우 입력. 없으면 공용 키를 자동 사용.
KIS_US_API_KEY=
KIS_US_API_SECRET=
KIS_US_ACC_NO=

# ── Seed Tickers ─────────────────────────────────────────────────────
# 한국 종목: 쉼표 구분 6자리 코드
TICKERS_KR=005930,000660,035420
# 미국 종목: 쉼표 구분 영문 티커
TICKERS_US=NVDA,AAPL
# (하위 호환) TICKERS_KR이 비어있으면 이 값을 KR로 사용
TICKERS=005930,000660,035420

# ── Portfolio Settings ───────────────────────────────────────────────
INITIAL_CASH=10000000
MAX_DRAWDOWN_PCT=0.03
MAX_ACTIVE_BOTS=10
# 미국 주식에 배분할 비율 (0.3 = 30%)
US_ALLOCATION_PCT=0.3

# ── Strategy ─────────────────────────────────────────────────────────
POLL_INTERVAL=10
SMA_PERIOD=20
THRESHOLD=0.005
BULLISH_THRESHOLD=0.75
TRAILING_STOP_PCT=0.02

# ── Scanner ──────────────────────────────────────────────────────────
SCAN_INTERVAL=900

# ── ML / Backtest ───────────────────────────────────────────────────
ML_MODEL_PATH=models/lgbm_v1.pkl
ML_THRESHOLD_BUY=0.55
ML_THRESHOLD_SELL=0.45
STOP_LOSS_PCT=-0.05
BT_TRAIN_WINDOW=756
BT_TEST_WINDOW=63
BT_HORIZON=10

# ── Triple Barrier Labeling ─────────────────────────────────────────
# Profit target = entry + BT_PT_ATR_MULT * ATR_14
# Stop loss     = entry - BT_SL_ATR_MULT * ATR_14
# Asymmetric (PT=2, SL=1) reflects typical risk/reward in trend trading
BT_PT_ATR_MULT=2.0
BT_SL_ATR_MULT=1.0

# ── Entry Mode ───────────────────────────────────────────────────────
# eod      = End-of-Day: evaluate once per day near close (recommended)
# intraday = Legacy mode: 10-second polling with momentum threshold
ENTRY_MODE=eod
MAX_TRADES_PER_DAY=2

# ── Phase 2: Model Architecture ─────────────────────────────────────
USE_ENSEMBLE=true          # LGB + XGB + CatBoost averaging
USE_META_LABELING=true     # 2-stage ML (primary permissive + meta filter)
USE_VOL_INDEX=true         # Include VKOSPI/VIX as regime features

# ── FX (환율) ───────────────────────────────────────────────────────
# 실시간 환율 조회 실패 시 사용할 기본 USD/KRW
DEFAULT_USDKRW=1380.0

# ── Phase 3: Portfolio Management ───────────────────────────────────
USE_KELLY_SIZING=true
KELLY_MULTIPLIER=0.25
TARGET_PORTFOLIO_VOL=0.15
KELLY_MAX_WEIGHT=0.10
MAX_SECTOR_EXPOSURE=0.30
PORTFOLIO_STOP=-0.05
PORTFOLIO_KILL=-0.10

USE_CS_SCANNER=true
CS_SCANNER_TOP_N=15
